{
  "accessibility": {
    "disableLoadingPhrases": true
  },
  "checkpointing": {
    "enabled": true
  },
  "theme": "Default",
  "model": {
    "name": "gemini-3-flash-preview"
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "previewFeatures": true,
    "preferredEditor": "vim",
    "vimMode": true,
    "defaultApprovalMode": "auto_edit",
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "tools": {
    "allowed": [
      "run_shell_command(*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/scripts/gemini-hook-notify"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/scripts/gemini-hook-notify"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.gemini/scripts/gemini-hook-notify"
          }
        ]
      }
    ]
  }
}