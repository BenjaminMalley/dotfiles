#!/usr/bin/env swift
import Foundation
import AppKit
import os

// --- Configuration ---
let logger = Logger(subsystem: "com.dotfiles.scripts", category: "check-junk-mail")

// --- Helper Extensions ---

extension NSAppleEventDescriptor {
    /// Safely extracts a list of strings from an Apple Event descriptor
    var stringArrayValue: [String] {
        var result = [String]()
        let count = self.numberOfItems
        if count == 0 {
            if let str = self.stringValue {
                return [str]
            }
            return []
        }
        for i in 1...count {
            if let item = self.atIndex(i)?.stringValue {
                result.append(item)
            }
        }
        return result
    }
}

// --- Helper Functions ---

func runAppleScript(_ source: String) -> NSAppleEventDescriptor? {
    guard let script = NSAppleScript(source: source) else {
        fputs("Failed to initialize AppleScript source.\n", stderr)
        return nil
    }
    
    var error: NSDictionary?
    let result = script.executeAndReturnError(&error)
    
    if let err = error {
        if let message = err["NSAppleScriptErrorMessage"] as? String {
            fputs("AppleScript Error: \(message)\n", stderr)
        } else {
            fputs("AppleScript Error: \(err)\n", stderr)
        }
        return nil
    }
    
    return result
}

func callGemini(prompt: String) -> String {
    let process = Process()
    process.executableURL = URL(fileURLWithPath: "/usr/bin/env")
    process.arguments = ["gemini"]
    
    let inputPipe = Pipe()
    let outputPipe = Pipe()
    process.standardInput = inputPipe
    process.standardOutput = outputPipe
    
    do {
        try process.run()
        if let data = prompt.data(using: .utf8) {
            inputPipe.fileHandleForWriting.write(data)
        }
        inputPipe.fileHandleForWriting.closeFile()
        process.waitUntilExit()
        
        let data = outputPipe.fileHandleForReading.readDataToEndOfFile()
        let result = String(data: data, encoding: .utf8)?.trimmingCharacters(in: .whitespacesAndNewlines) ?? ""
        return result.isEmpty ? "Error: No response" : result
    } catch {
        return "Error: \(error)"
    }
}

// --- Main Execution ---

print("Searching for messages in Junk/Spam mailboxes...")

// This script returns a flat list: {accountName, msgId, accountName, msgId, ...}
let getIdsScriptSource = """
set idList to {}
tell application "Mail"
    repeat with eachAccount in accounts
        set accountName to name of eachAccount
        set possibleMailboxes to {"Junk", "Spam"}
        
        try
            set theMailbox to junk mailbox of eachAccount
            set theMessages to messages of theMailbox
            repeat with aMessage in theMessages
                set end of idList to accountName
                set end of idList to (id of aMessage as string)
            end repeat
        on error
            repeat with mName in possibleMailboxes
                try
                    set theMailbox to mailbox mName of eachAccount
                    set theMessages to messages of theMailbox
                    repeat with aMessage in theMessages
                        set end of idList to accountName
                        set end of idList to (id of aMessage as string)
                    end repeat
                    exit repeat
                end try
            end repeat
        end try
    end repeat
end tell
return idList
"""

guard let idsDescriptor = runAppleScript(getIdsScriptSource) else {
    exit(1)
}

let flatList = idsDescriptor.stringArrayValue
guard !flatList.isEmpty else {
    print("No messages found in Junk mailboxes.")
    exit(0)
}

var junkCount = 0
var notJunkCount = 0

// Iterate through the flat list in pairs (Account, ID)
for i in stride(from: 0, to: flatList.count, by: 2) {
    let accountName = flatList[i]
    let msgId = flatList[i+1]
    
    print("Processing Account: \(accountName), ID: \(msgId)...")
    
    let getMsgScriptSource = """
    tell application "Mail"
        set theAccount to account "\(accountName)"
        set theMessage to missing value
        
        try
            set theMailbox to junk mailbox of theAccount
            set theMessage to (first message of theMailbox whose id is \(msgId))
        on error
            set possibleMailboxes to {"Junk", "Spam"}
            repeat with mName in possibleMailboxes
                try
                    set theMailbox to mailbox mName of theAccount
                    set theMessage to (first message of theMailbox whose id is \(msgId))
                    exit repeat
                end try
            end repeat
        end try
        
        if theMessage is not missing value then
            return {subject of theMessage, content of theMessage}
        else
            return {}
        end if
    end tell
    """
    
    guard let msgDescriptor = runAppleScript(getMsgScriptSource) else { continue }
    let msgDetails = msgDescriptor.stringArrayValue
    guard msgDetails.count >= 1 else { continue }
    
    let subject = msgDetails[0]
    let content = msgDetails.count > 1 ? msgDetails[1] : ""
    
    let prompt = """
    You are an expert email filter. Given the following email details, determine if it is 'Junk' (spam, marketing, unwanted) or 'Not Junk' (personal, transactional, important). Respond with ONLY 'Junk' or 'Not Junk'.

    Subject: \(subject)
    Content:
    \(content)
    """
    
    let classification = callGemini(prompt: prompt)
    
    logger.info("Classification: \(classification), Account: \(accountName), Subject: \(subject), ID: \(msgId)")
    
    let actionScriptSource: String
    if classification.contains("Not Junk") {
        notJunkCount += 1
        print("Moving to Inbox: \(subject)")
        actionScriptSource = """
        tell application "Mail"
            try
                set theAccount to account "\(accountName)"
                set theInbox to mailbox "INBOX" of theAccount
                set theMessage to missing value
                
                try
                    set theMailbox to junk mailbox of theAccount
                    set theMessage to (first message of theMailbox whose id is \(msgId))
                on error
                    set possibleMailboxes to {"Junk", "Spam"}
                    repeat with mName in possibleMailboxes
                        try
                            set theMailbox to mailbox mName of theAccount
                            set theMessage to (first message of theMailbox whose id is \(msgId))
                            exit repeat
                        end try
                    end repeat
                end try
                
                if theMessage is not missing value then
                    move theMessage to theInbox
                    return "Success"
                end if
            on error errMsg
                return "Error: " & errMsg
            end try
        end tell
        """
    } else {
        junkCount += 1
        print("Deleting Junk: \(subject)")
        actionScriptSource = """
        tell application "Mail"
            try
                set theAccount to account "\(accountName)"
                set theMessage to missing value
                
                try
                    set theMailbox to junk mailbox of theAccount
                    set theMessage to (first message of theMailbox whose id is \(msgId))
                on error
                    set possibleMailboxes to {"Junk", "Spam"}
                    repeat with mName in possibleMailboxes
                        try
                            set theMailbox to mailbox mName of theAccount
                            set theMessage to (first message of theMailbox whose id is \(msgId))
                            exit repeat
                        end try
                    end repeat
                end try
                
                if theMessage is not missing value then
                    delete theMessage
                    return "Success"
                end if
            on error errMsg
                return "Error: " & errMsg
            end try
        end tell
        """
    }
    
    if let actionResult = runAppleScript(actionScriptSource)?.stringValue, actionResult.hasPrefix("Error:") {
        print("Failed to process message: \(actionResult)")
    }
}

let summary = """
SUMMARY:
Total Messages Scanned: \(junkCount + notJunkCount)
Junk: \(junkCount)
Not Junk: \(notJunkCount)
"""
print(summary)
logger.info("\(summary)")
