#!/usr/bin/env python3

import sys
import os
import subprocess
import argparse

def get_other_pane():
    """Finds a pane in the current window that is not the active one."""
    try:
        # List panes: id, active_flag, current_command
        output = subprocess.check_output(
            ['tmux', 'list-panes', '-F', '#{pane_id}:#{pane_active}:#{pane_current_command}'],
            text=True
        ).strip().split('\n')
        
        current_pane = None
        other_panes = []
        
        for line in output:
            p_id, active, cmd = line.split(':')
            if active == '1':
                current_pane = p_id
            else:
                other_panes.append((p_id, cmd))
        
        if not other_panes:
            return None, None
            
        # Return the first non-active pane
        return other_panes[0]
        
    except subprocess.CalledProcessError:
        return None, None

def main():
    parser = argparse.ArgumentParser(description="Open file in the adjacent tmux pane's Vim.")
    parser.add_argument("filename", nargs="?", help="File to open", default=None)
    parser.add_argument("line", nargs="?", help="Line number", default=None)
    args = parser.parse_args()
    
    # Find target pane
    target_pane_id, pane_cmd = get_other_pane()
    
    if not target_pane_id:
        print("Error: Could not find another pane in the current tmux window.")
        sys.exit(1)
        
    # Check if the target pane is running vim, vi, or nvim
    is_vim = any(cmd in pane_cmd.lower() for cmd in ['vim', 'vi', 'nvim'])
    
    # Construct Tmux commands
    cmds = []
    
    if is_vim:
        cmds.append(['tmux', 'send-keys', '-t', target_pane_id, 'Escape'])
        
        if args.filename:
            # Open/Reload specific file
            abs_path = os.path.abspath(args.filename)
            cmds.append(['tmux', 'send-keys', '-t', target_pane_id, f':e {abs_path}', 'Enter'])
        else:
            # Just refresh current buffer
            cmds.append(['tmux', 'send-keys', '-t', target_pane_id, ':checktime', 'Enter'])
    else:
        if args.filename:
            # Start vim with the file
            abs_path = os.path.abspath(args.filename)
            cmds.append(['tmux', 'send-keys', '-t', target_pane_id, f'vim {abs_path}', 'Enter'])
        
    # Handle line number
    if args.line and args.filename:
        cmds.append(['tmux', 'send-keys', '-t', target_pane_id, f':{args.line}', 'Enter'])
        
    # Execute commands
    for cmd in cmds:
        subprocess.run(cmd, check=True)

if __name__ == "__main__":
    main()
